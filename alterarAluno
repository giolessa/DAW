<?php
$msg = "";
$aluno = ["", "", ""]; 

if (isset($_POST['botaoBuscar'])) {
    $mat = $_POST["matricula"];
    $arq = fopen("alunos.csv", "r") or die("Erro ao abrir arquivo!");
    while (($dados = fgetcsv($arq, 0, ";")) !== FALSE) {
        if ($dados[0] == $mat) {
            $aluno = $dados;
            $msg = "Achei o aluno!";
            break;
        }
    }
    fclose($arq);
    if ($aluno[0] == "") $msg = "Matrícula não existe";
}

if (isset($_POST['botaoAlterar'])) {
    $mat  = $_POST["matricula"];
    $nome = $_POST["nome"];
    $mail = $_POST["email"];
    $temp = [];
    
    $arq = fopen("alunos.csv", "r") or die("Erro de leitura");
    while (($dados = fgetcsv($arq, 0, ";")) !== FALSE) {
        if ($dados[0] == $mat) {
            $temp[] = [$mat, $nome, $mail];
        } else {
            $temp[] = $dados;
        }
    }
    fclose($arq);

    $arq = fopen("alunos.csv", "w") or die("Erro na escrita");
    foreach ($temp as $linha) {
        fputcsv($arq, $linha, ";");
    }
    fclose($arq);
    $msg = "Alterado com sucesso!";
}
?>

